#!/usr/bin/env bash
set -euo pipefail

workspace_root="${HUB_WORKSPACE_ROOT:-/workspaces/dotfiles}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
source "$script_dir/../scripts/lib/did-you-mean.sh"

usage() {
  printf 'usage: dre <repo>\n' >&2
}

metadata_refusal() {
  local repo_name="$1"
  printf 'refused: managed child default branch metadata is missing or invalid for "%s"\n' "$repo_name" >&2
}

metadata_repair_hint() {
  local repo_name="$1"
  local repo_root="$2"
  local helper_path="$(cd "$script_dir/../scripts/lib" && pwd -P)/write-managed-repo-env.sh"
  local suggested_branch=''
  local suggested_dir=''

  if [ -d "$repo_root/main" ]; then
    suggested_branch='main'
  elif [ -d "$repo_root/master" ]; then
    suggested_branch='master'
  fi

  if [ -z "$suggested_branch" ]; then
    suggested_branch='main'
  fi

  suggested_dir="$repo_root/$suggested_branch"

  printf 'to repair, run:\n' >&2
  printf '  HUB_WORKSPACE_ROOT="%s" bash %s "%s" "%s" "%s"\n' "$workspace_root" "$helper_path" "$repo_name" "$suggested_branch" "$suggested_dir" >&2
}

fail_metadata() {
  local repo_name="$1"
  local repo_root="$2"
  metadata_refusal "$repo_name"
  metadata_repair_hint "$repo_name" "$repo_root"
  exit 1
}

if [ "$#" -ne 1 ]; then
  usage
  exit 2
fi

repo="$1"
case "$repo" in
  hub|dotfiles|main|work|repos|.|..|/|"$workspace_root"|"$workspace_root/main")
    printf 'refused: top-level hub root is not a valid dre target\n' >&2
    exit 1
    ;;
esac

repos_root="$workspace_root/repos"
target="$repos_root/$repo"

if [ ! -d "$target" ] || [ ! -d "$target/.bare" ]; then
  repo_candidates=()
  if [ -d "$repos_root" ]; then
    while IFS= read -r path; do
      name="${path##*/}"
      [ -d "$path/.bare" ] || continue
      repo_candidates+=("$name")
    done < <(find "$repos_root" -mindepth 1 -maxdepth 1 -type d)
  fi

  printf 'refused: repo "%s" not found\n' "$repo" >&2
  did_you_mean "$repo" "${repo_candidates[@]:-}"
  exit 1
fi

repo_env="$workspace_root/state/repos/$repo/etc/repo.env"
default_dir=''
default_branch=''
target_canon=''
default_dir_canon=''

if [ ! -f "$repo_env" ]; then
  fail_metadata "$repo" "$target"
fi

# shellcheck disable=SC1090
if ! . "$repo_env" 2>/dev/null; then
  fail_metadata "$repo" "$target"
fi

default_branch="${DYN_REPO_DEFAULT_BRANCH:-}"
default_dir="${DYN_REPO_DEFAULT_DIR:-}"

if [ -z "$default_branch" ] || [ -z "$default_dir" ] || [ ! -d "$default_dir" ]; then
  fail_metadata "$repo" "$target"
fi

if ! target_canon="$(readlink -f "$target" 2>/dev/null)"; then
  fail_metadata "$repo" "$target"
fi

if ! default_dir_canon="$(readlink -f "$default_dir" 2>/dev/null)"; then
  fail_metadata "$repo" "$target"
fi

case "$default_dir_canon" in
  "$target_canon"|"$target_canon"/*) ;;
  *)
    fail_metadata "$repo" "$target"
    ;;
esac

printf '%s\n' "$default_dir"
