#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=scripts/lib/hub-repo-core.sh
source "$script_dir/../scripts/lib/hub-repo-core.sh"

workspace_root="${HUB_WORKSPACE_ROOT:-/workspaces/dotfiles}"
"$script_dir/../scripts/lib/validate_hub_repo_root.sh" "$workspace_root/main" >/dev/null
metadata_writer="$script_dir/../scripts/lib/write-managed-repo-env.sh"

if [ ! -x "$metadata_writer" ]; then
  printf 'refused: missing managed repo metadata writer helper\n' >&2
  exit 1
fi

usage() {
  printf 'usage: clone-repo <public-repo-source>\n' >&2
}

if [ "$#" -eq 0 ]; then
  usage
  exit 2
fi

if [ "$1" = "--name" ]; then
  usage
  exit 2
fi

if [ "$#" -ne 1 ]; then
  usage
  exit 2
fi

source_repo="$1"

case "$source_repo" in
  git@*|ssh://*|*://*/*/*)
    case "$source_repo" in
      https://*) ;;
      *)
        printf 'refused: public repo source is required in v1\n' >&2
        exit 1
        ;;
    esac
    ;;
esac

repo_name="${source_repo##*/}"
repo_name="${repo_name%.git}"

if [ -z "$repo_name" ] || [ "$repo_name" = "." ] || [ "$repo_name" = ".." ]; then
  printf 'refused: could not derive repo name from source\n' >&2
  exit 1
fi

child_root="$workspace_root/repos/$repo_name"

if [ -e "$child_root" ]; then
  printf 'refused: child repo path already exists\n' >&2
  exit 1
fi

create_bare_hub "$child_root" "$source_repo" main yes
default_branch="${HUB_REPO_RESOLVED_BRANCH:-main}"
default_dir="$child_root/$default_branch"

if [ "$default_branch" != "main" ]; then
  if git --git-dir="$child_root/.bare" worktree list --porcelain | grep -F "worktree $child_root/main" >/dev/null 2>&1; then
    git --git-dir="$child_root/.bare" worktree remove --force "$child_root/main" >/dev/null
  fi
  if git --git-dir="$child_root/.bare" worktree list --porcelain | grep -F "worktree $default_dir" >/dev/null 2>&1; then
    :
  else
    git --git-dir="$child_root/.bare" worktree add "$default_dir" "$default_branch" >/dev/null
  fi
fi

mkdir -p "$workspace_root/state/repos/$repo_name/$default_branch"
mkdir -p "$workspace_root/tmp/repos/$repo_name/$default_branch"

HUB_WORKSPACE_ROOT="$workspace_root" bash "$metadata_writer" "$repo_name" "$default_branch" "$default_dir"

"$script_dir/../scripts/lib/worktree-env.sh" "$default_dir" child "$repo_name" >/dev/null

printf 'ok: created child hub repo at %s\n' "$child_root"
