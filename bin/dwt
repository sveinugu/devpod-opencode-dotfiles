#!/usr/bin/env bash
set -euo pipefail

workspace_root="${HUB_WORKSPACE_ROOT:-/workspaces/dotfiles}"
pwd_dir="${PWD:-$(pwd -P)}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
source "$script_dir/../scripts/lib/did-you-mean.sh"
source "$script_dir/../scripts/lib/managed-repo-metadata.sh"

usage() {
  printf 'usage: dwt [name]\n' >&2
}

if [ "$#" -gt 1 ]; then
  usage
  exit 2
fi

resolver="${WORKSPACE_NAV_REPO_ROOT_RESOLVER:-$script_dir/../scripts/lib/resolve-managed-repo-root.sh}"
repo_root=''
if ! repo_root="$(HUB_WORKSPACE_ROOT="$workspace_root" bash "$resolver" "$pwd_dir" 2>/dev/null)"; then
  printf 'refused: dwt requires a managed repo checkout context\n' >&2
  exit 1
fi

default_branch=''
default_dir=''
if [ "$repo_root" = "$workspace_root" ]; then
  default_branch='main'
  default_dir="$repo_root/main"
else
  repo_name="${repo_root#"$workspace_root/repos/"}"
  repo_env="$workspace_root/state/repos/$repo_name/etc/repo.env"
  repo_root_canon=''
  default_dir_canon=''
  if [ ! -f "$repo_env" ]; then
    fail_metadata "$repo_name" "$repo_root" "$workspace_root" "$script_dir"
  fi

  if ! repo_root_canon="$(readlink -f "$repo_root" 2>/dev/null)"; then
    fail_metadata "$repo_name" "$repo_root" "$workspace_root" "$script_dir"
  fi

  # shellcheck disable=SC1090
  if ! . "$repo_env" 2>/dev/null; then
    fail_metadata "$repo_name" "$repo_root" "$workspace_root" "$script_dir"
  fi

  default_branch="${DYN_REPO_DEFAULT_BRANCH:-}"
  default_dir="${DYN_REPO_DEFAULT_DIR:-}"
  if [ -z "$default_branch" ] || [ -z "$default_dir" ] || [ ! -d "$default_dir" ]; then
    fail_metadata "$repo_name" "$repo_root" "$workspace_root" "$script_dir"
  fi

  if ! default_dir_canon="$(readlink -f "$default_dir" 2>/dev/null)"; then
    fail_metadata "$repo_name" "$repo_root" "$workspace_root" "$script_dir"
  fi

  case "$default_dir_canon" in
    "$repo_root_canon"|"$repo_root_canon"/*) ;;
    *)
      fail_metadata "$repo_name" "$repo_root" "$workspace_root" "$script_dir"
      ;;
  esac

  default_dir="$default_dir_canon"
fi

if [ "$#" -eq 0 ]; then
  printf '%s\n' "$default_dir"
  exit 0
fi

name="$1"
if [ "$name" = "$default_branch" ]; then
  printf '%s\n' "$default_dir"
  exit 0
fi

target="$repo_root/work/$name"
if [ ! -d "$target" ]; then
  candidates=()
  if [ -d "$repo_root/work" ]; then
    while IFS= read -r path; do
      candidates+=("${path##*/}")
    done < <(find "$repo_root/work" -mindepth 1 -maxdepth 1 -type d)
  fi
  printf 'refused: worktree "%s" not found\n' "$name" >&2
  did_you_mean "$name" "${candidates[@]:-}"
  exit 1
fi

printf '%s\n' "$target"
