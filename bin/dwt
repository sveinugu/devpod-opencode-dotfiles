#!/usr/bin/env bash
set -euo pipefail

workspace_root="${HUB_WORKSPACE_ROOT:-/workspaces/dotfiles}"
pwd_dir="${PWD:-$(pwd -P)}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

usage() {
  printf 'usage: dwt <name>\n' >&2
}

did_you_mean() {
  local needle="$1"
  shift

  [ "$#" -gt 0 ] || return 0

  local suggestion
  suggestion="$(python3 - "$needle" "$@" <<'PY'
import difflib
import sys

needle = sys.argv[1]
candidates = sys.argv[2:]
matches = difflib.get_close_matches(needle, candidates, n=1, cutoff=0.5)
if matches:
    print(matches[0])
PY
)"

  if [ -n "$suggestion" ]; then
    printf 'did you mean: %s\n' "$suggestion" >&2
  fi
}

if [ "$#" -ne 1 ]; then
  usage
  exit 2
fi

name="$1"

resolver="${WORKSPACE_NAV_REPO_ROOT_RESOLVER:-$script_dir/../scripts/lib/resolve-managed-repo-root.sh}"
repo_root=''
if ! repo_root="$(HUB_WORKSPACE_ROOT="$workspace_root" bash "$resolver" "$pwd_dir" 2>/dev/null)"; then
  printf 'refused: dwt requires a managed repo checkout context\n' >&2
  exit 1
fi

target="$repo_root/work/$name"
if [ ! -d "$target" ]; then
  candidates=()
  if [ -d "$repo_root/work" ]; then
    while IFS= read -r path; do
      candidates+=("${path##*/}")
    done < <(find "$repo_root/work" -mindepth 1 -maxdepth 1 -type d)
  fi
  printf 'refused: worktree "%s" not found\n' "$name" >&2
  did_you_mean "$name" "${candidates[@]:-}"
  exit 1
fi

printf '%s\n' "$target"
