#!/usr/bin/env bash
set -euo pipefail

workspace_root="${HUB_WORKSPACE_ROOT:-/workspaces/dotfiles}"
pwd_dir="${PWD:-$(pwd -P)}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
source "$script_dir/../scripts/lib/did-you-mean.sh"
source "$script_dir/../scripts/lib/managed-repo-metadata.sh"
source "$script_dir/../scripts/lib/resolve-managed-default-checkout.sh"

usage() {
  printf 'usage: dwt [name]\n' >&2
}

if [ "$#" -gt 1 ]; then
  usage
  exit 2
fi

resolver="${WORKSPACE_NAV_REPO_ROOT_RESOLVER:-$script_dir/../scripts/lib/resolve-managed-repo-root.sh}"
repo_root=''
if ! repo_root="$(HUB_WORKSPACE_ROOT="$workspace_root" bash "$resolver" "$pwd_dir" 2>/dev/null)"; then
  printf 'refused: dwt requires a managed repo checkout context\n' >&2
  exit 1
fi

default_branch=''
default_dir=''
if [ "$repo_root" = "$workspace_root" ]; then
  default_branch='main'
  default_dir="$repo_root/main"
else
  repo_name="${repo_root#"$workspace_root/repos/"}"
  resolve_managed_default_checkout "$repo_name" "$repo_root" "$workspace_root" "$script_dir"
  default_branch="${MANAGED_REPO_DEFAULT_BRANCH:-}"
  default_dir="${MANAGED_REPO_DEFAULT_DIR_CANON:-}"
fi

if [ "$#" -eq 0 ]; then
  printf '%s\n' "$default_dir"
  exit 0
fi

name="$1"
if [ "$name" = "$default_branch" ]; then
  printf '%s\n' "$default_dir"
  exit 0
fi

target="$repo_root/work/$name"
if [ ! -d "$target" ]; then
  candidates=()
  if [ -d "$repo_root/work" ]; then
    while IFS= read -r path; do
      candidates+=("${path##*/}")
    done < <(find "$repo_root/work" -mindepth 1 -maxdepth 1 -type d)
  fi
  printf 'refused: worktree "%s" not found\n' "$name" >&2
  did_you_mean "$name" "${candidates[@]:-}"
  exit 1
fi

printf '%s\n' "$target"
