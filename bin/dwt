#!/usr/bin/env bash
set -euo pipefail

workspace_root="${HUB_WORKSPACE_ROOT:-/workspaces/dotfiles}"
pwd_dir="${PWD:-$(pwd -P)}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

usage() {
  printf 'usage: dwt [name]\n' >&2
}

metadata_refusal() {
  local repo_name="$1"
  printf 'refused: managed child default branch metadata is missing or invalid for "%s"\n' "$repo_name" >&2
}

metadata_repair_hint() {
  local repo_name="$1"
  local repo_root="$2"
  local helper_path="$(cd "$script_dir/../scripts/lib" && pwd -P)/write-managed-repo-env.sh"
  local suggested_branch=''
  local suggested_dir=''

  if [ -d "$repo_root/main" ]; then
    suggested_branch='main'
  elif [ -d "$repo_root/master" ]; then
    suggested_branch='master'
  fi

  if [ -z "$suggested_branch" ]; then
    suggested_branch='main'
  fi

  suggested_dir="$repo_root/$suggested_branch"

  printf 'to repair, run:\n' >&2
  printf '  HUB_WORKSPACE_ROOT="%s" bash %s "%s" "%s" "%s"\n' "$workspace_root" "$helper_path" "$repo_name" "$suggested_branch" "$suggested_dir" >&2
}

fail_metadata() {
  local repo_name="$1"
  local repo_root="$2"
  metadata_refusal "$repo_name"
  metadata_repair_hint "$repo_name" "$repo_root"
  exit 1
}

did_you_mean() {
  local needle="$1"
  shift

  [ "$#" -gt 0 ] || return 0

  local suggestion
  suggestion="$(python3 - "$needle" "$@" <<'PY'
import difflib
import sys

needle = sys.argv[1]
candidates = sys.argv[2:]
matches = difflib.get_close_matches(needle, candidates, n=1, cutoff=0.5)
if matches:
    print(matches[0])
PY
)"

  if [ -n "$suggestion" ]; then
    printf 'did you mean: %s\n' "$suggestion" >&2
  fi
}

if [ "$#" -gt 1 ]; then
  usage
  exit 2
fi

resolver="${WORKSPACE_NAV_REPO_ROOT_RESOLVER:-$script_dir/../scripts/lib/resolve-managed-repo-root.sh}"
repo_root=''
if ! repo_root="$(HUB_WORKSPACE_ROOT="$workspace_root" bash "$resolver" "$pwd_dir" 2>/dev/null)"; then
  printf 'refused: dwt requires a managed repo checkout context\n' >&2
  exit 1
fi

default_branch=''
default_dir=''
if [ "$repo_root" = "$workspace_root" ]; then
  default_branch='main'
  default_dir="$repo_root/main"
else
  repo_name="${repo_root#"$workspace_root/repos/"}"
  repo_env="$workspace_root/state/repos/$repo_name/etc/repo.env"
  if [ ! -f "$repo_env" ]; then
    fail_metadata "$repo_name" "$repo_root"
  fi
  # shellcheck disable=SC1090
  . "$repo_env"
  default_branch="${DYN_REPO_DEFAULT_BRANCH:-}"
  default_dir="${DYN_REPO_DEFAULT_DIR:-}"
  if [ -z "$default_branch" ] || [ -z "$default_dir" ] || [ ! -d "$default_dir" ]; then
    fail_metadata "$repo_name" "$repo_root"
  fi
fi

if [ "$#" -eq 0 ]; then
  printf '%s\n' "$default_dir"
  exit 0
fi

name="$1"
if [ "$name" = "$default_branch" ]; then
  printf '%s\n' "$default_dir"
  exit 0
fi

target="$repo_root/work/$name"
if [ ! -d "$target" ]; then
  candidates=()
  if [ -d "$repo_root/work" ]; then
    while IFS= read -r path; do
      candidates+=("${path##*/}")
    done < <(find "$repo_root/work" -mindepth 1 -maxdepth 1 -type d)
  fi
  printf 'refused: worktree "%s" not found\n' "$name" >&2
  did_you_mean "$name" "${candidates[@]:-}"
  exit 1
fi

printf '%s\n' "$target"
