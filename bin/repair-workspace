#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -ne 0 ]; then
  printf 'usage: repair-workspace\n' >&2
  exit 2
fi

workspace_root="${HUB_WORKSPACE_ROOT:-/workspaces/dotfiles}"
home_dir="${HUB_HOME_DIR:-/home/vscode}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
read_install_env_script="$script_dir/../scripts/lib/read-install-env.sh"

refuse() {
  printf '%s\n' "$1" >&2
  exit 1
}

run_step() {
  local step="$1"
  shift

  if ! "$@"; then
    printf 'error: workspace repair failed during %s\n' "$step" >&2
    exit 1
  fi
}

ensure_dir_path() {
  local path="$1"
  if [ -e "$path" ] && [ ! -d "$path" ]; then
    refuse 'refused: managed path conflicts by type'
  fi
  mkdir -p "$path"
}

if ! git --git-dir="$workspace_root/.bare" rev-parse --is-bare-repository >/dev/null 2>&1; then
  refuse 'refused: existing .bare path is invalid'
fi

run_step 'ensure managed directory work/' ensure_dir_path "$workspace_root/work"
run_step 'ensure managed directory repos/' ensure_dir_path "$workspace_root/repos"
run_step 'ensure managed directory state/' ensure_dir_path "$workspace_root/state"
run_step 'ensure managed directory tmp/' ensure_dir_path "$workspace_root/tmp"
run_step 'ensure canonical state path state/hub/main' ensure_dir_path "$workspace_root/state/hub/main"
run_step 'ensure canonical tmp path tmp/hub/main' ensure_dir_path "$workspace_root/tmp/hub/main"

if git --git-dir="$workspace_root/.bare" worktree list --porcelain | grep -F "worktree $workspace_root/main" >/dev/null 2>&1; then
  main_branch="$(git -C "$workspace_root/main" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  fetched_origin_main=false
  if git --git-dir="$workspace_root/.bare" fetch origin refs/heads/main:refs/remotes/origin/main >/dev/null 2>&1; then
    fetched_origin_main=true
  fi

  if [ -n "$main_branch" ] && [ "$main_branch" != "main" ]; then
    run_step 'switch main worktree to branch main' git -C "$workspace_root/main" checkout main
  fi

  if [ "$fetched_origin_main" = true ] && git --git-dir="$workspace_root/.bare" show-ref --verify --quiet refs/remotes/origin/main; then
    run_step 'fast-forward main worktree to origin/main' git -C "$workspace_root/main" merge --ff-only origin/main
  fi
else
  if [ -e "$workspace_root/main" ] && [ ! -d "$workspace_root/main" ]; then
    refuse 'refused: managed path conflicts by type'
  fi
  if [ -e "$workspace_root/main" ]; then
    refuse 'refused: workspace identity is ambiguous'
  fi
  if ! git --git-dir="$workspace_root/.bare" show-ref --verify --quiet refs/heads/main; then
    refuse 'refused: workspace identity is ambiguous; refs/heads/main is missing'
  fi
  run_step 'reattach top-level main worktree' git --git-dir="$workspace_root/.bare" worktree add "$workspace_root/main" main >/dev/null
fi

resolve_install_branch() {
  if [ -n "${HUB_INSTALL_BRANCH:-}" ]; then
    printf '%s\n' "$HUB_INSTALL_BRANCH"
    return
  fi

  install_env="$workspace_root/state/hub/etc/install.env"
  if [ -f "$install_env" ]; then
    if [ -x "$read_install_env_script" ]; then
      eval "$(bash "$read_install_env_script" "$install_env")"
    fi
    install_branch="${HUB_INSTALL_BRANCH:-}"
    if [ -n "$install_branch" ]; then
      printf '%s\n' "$install_branch"
      return
    fi
  fi

  printf 'main\n'
}

install_branch="$(resolve_install_branch)"
if [ "$install_branch" = "main" ]; then
  install_dir="$workspace_root/main"
  run_step 'ensure canonical state path for install branch main' ensure_dir_path "$workspace_root/state/hub/main"
  run_step 'ensure canonical tmp path for install branch main' ensure_dir_path "$workspace_root/tmp/hub/main"
else
  install_dir="$workspace_root/work/$install_branch"
  if ! git --git-dir="$workspace_root/.bare" show-ref --verify --quiet "refs/heads/$install_branch"; then
    refuse "refused: workspace identity is ambiguous; refs/heads/$install_branch is missing"
  fi
  run_step "ensure canonical state path state/hub/work/$install_branch" ensure_dir_path "$workspace_root/state/hub/work/$install_branch"
  run_step "ensure canonical tmp path tmp/hub/work/$install_branch" ensure_dir_path "$workspace_root/tmp/hub/work/$install_branch"

  if git --git-dir="$workspace_root/.bare" worktree list --porcelain | grep -F "worktree $install_dir" >/dev/null 2>&1; then
    :
  else
    mkdir -p "$(dirname "$install_dir")"
    run_step "attach install worktree $install_branch" git --git-dir="$workspace_root/.bare" worktree add "$install_dir" "$install_branch" >/dev/null
  fi

  fetched_install_branch=false
  if git --git-dir="$workspace_root/.bare" fetch origin "refs/heads/$install_branch:refs/remotes/origin/$install_branch" >/dev/null 2>&1; then
    fetched_install_branch=true
  fi
  if [ "$fetched_install_branch" = true ] && git --git-dir="$workspace_root/.bare" show-ref --verify --quiet "refs/remotes/origin/$install_branch"; then
    run_step "fast-forward install worktree $install_branch" git -C "$install_dir" merge --ff-only "origin/$install_branch"
  fi
fi

preserve_non_main=false
for rel in .zshrc .zprofile .config/opencode; do
  path="$home_dir/$rel"
  if [ ! -L "$path" ]; then
    continue
  fi
  target="$(readlink "$path")"
  case "$target" in
    "$workspace_root/work"/*)
      target_parent="$(dirname "$target")"
      if [ -d "$target_parent" ]; then
        preserve_non_main=true
      fi
      ;;
  esac
done

if [ "$preserve_non_main" = false ]; then
  install_step_label="run $install_dir/install.sh"
  if [ "$install_branch" = "main" ]; then
    install_step_label='run main/install.sh'
  fi

  if [ ! -x "$install_dir/install.sh" ]; then
    run_step "chmod $install_dir/install.sh" chmod +x "$install_dir/install.sh"
  fi
  run_step "$install_step_label" env HOME="$home_dir" HUB_INSTALL_BRANCH="$install_branch" HUB_INSTALL_BRANCH_DIR="$install_dir" "$install_dir/install.sh"

  install_ok=true
  for rel in .zshrc .zprofile .config/opencode; do
    link_path="$home_dir/$rel"
    if [ -L "$link_path" ]; then
      target="$(readlink "$link_path")"
      if [ ! -e "$target" ]; then
        printf 'error: workspace repair failed during run %s/install.sh (symlink target %s -> %s does not exist)\n' "$install_dir" "$rel" "$target" >&2
        install_ok=false
      fi
    fi
  done

  if [ "$install_ok" = false ]; then
    exit 1
  fi
fi

printf 'ok: repaired workspace structure at %s\n' "$workspace_root"
