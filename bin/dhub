#!/usr/bin/env bash
set -euo pipefail

install_env="/workspaces/dotfiles/state/hub/etc/install.env"

if [ ! -f "$install_env" ]; then
  printf 'refused: install branch state is missing\n' >&2
  exit 1
fi

# shellcheck disable=SC1090
. "$install_env"

target="${HUB_INSTALL_BRANCH_DIR:-}"
if [ -z "$target" ] || [ ! -d "$target" ]; then
  printf 'refused: install branch directory is missing or invalid\n' >&2
  exit 1
fi

printf '%s\n' "$target"
