{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "maestro",
  "model": "github-copilot/gpt-5-mini",
  "small_model": "github-copilot/gpt-5-mini",
  "plugin": [
    "oc-plugin-karpathy-guidelines@latest",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@bybrawe/opencode-loop"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "which *": "allow",
      "type *": "allow",
      "echo *": "allow",
      "true": "allow",
      "false": "allow",
      "sort": "allow",
      "cut *": "allow",
      "tee *": "allow",
      "wc *": "allow",
      "test *": "allow",
      "mkdir *": "allow",
      "git log*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git rev-parse*": "allow",
      "git merge-base*": "allow",
      "git worktree list*": "allow",
      "git ls-tree*": "allow",
      "git commit*": "ask",
      "git add*": "ask",
      "git worktree add*": "ask",
      "git reset*": "ask",
      "git revert*": "ask",
      "sed *": "allow",
      "sed -i*": "ask",
      "git push*": "deny",
      "rm *": "deny",
      "ssh*": "deny",
      "scp*": "deny",
      "sftp*": "deny",
      "ftp*": "deny"
    },
    "external_directory": {
      "/workspaces/dotfiles/**": "allow",
      "/home/vscode/.config/opencode/**": "allow",
      "/home/vscode/.local/share/opencode/**": "allow",
      "**": "ask"
    }
  },
  "agent": {
    "build": {
      "model": "github-copilot/gpt-5-mini"
    },
    "plan": {
      "model": "github-copilot/gpt-5.4"
    },
    "general": {
      "model": "github-copilot/gpt-5.4"
    },
    "explore": {
      "model": "github-copilot/gpt-5.4"
    },
    "title": {
      "model": "github-copilot/gpt-5-mini"
    },
    "summary": {
      "model": "github-copilot/gpt-5-mini"
    },
    "compaction": {
      "model": "github-copilot/gpt-5-mini"
    }
  },
  "lsp": true
}
