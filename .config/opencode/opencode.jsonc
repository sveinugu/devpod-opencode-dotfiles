{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "maestro",
  "model": "github-copilot/gpt-5-mini",
  "small_model": "github-copilot/gpt-5-mini",
  "plugin": [
    "oc-plugin-karpathy-guidelines@latest",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "./plugins/copilot-stats.ts",
    "@bybrawe/opencode-loop"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "sort *": "allow",
      "cut *": "allow",
      "tee *": "allow",
      "wc *": "allow",
      "git log*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch": "allow",
      "git ls-tree": "allow",
      "git commit*": "ask",
      "git add*": "ask",
      "git push*": "deny",
      "rm *": "deny",
      "ssh*": "deny",
      "scp*": "deny",
      "sftp*": "deny",
      "ftp*": "deny",
    }
  },
  "agent": {
    "build": {
      "model": "github-copilot/gpt-5-mini"
    },
    "plan": {
      "model": "github-copilot/gpt-5.4"
    },
    "general": {
      "model": "github-copilot/gpt-5.4"
    },
    "explore": {
      "model": "github-copilot/gpt-5.4"
    },
    "title": {
      "model": "github-copilot/gpt-5-mini"
    },
    "summary": {
      "model": "github-copilot/gpt-5-mini"
    },
    "compaction": {
      "model": "github-copilot/gpt-5-mini"
    }
  },
  "lsp": true
}
