{
  "meta": {
    "name": "devspace-opencode-secure",
    "description": "DevSpace secure OpenCode profile with explicit provider credential routes"
  },
  "groups": {
    "exclude": [
      "dangerous_commands",
      "dangerous_commands_linux"
    ]
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "read": [
      "$WORKDIR/.zshrc",
      "$WORKDIR/.zprofile"
    ],
    "allow": [
      "$HOME/.opencode",
      "$XDG_CONFIG_HOME/opencode",
      "$XDG_CACHE_HOME/opencode",
      "$XDG_DATA_HOME/opencode",
      "$XDG_DATA_HOME/opentui",
      "$XDG_STATE_HOME/opencode",
      "/tmp"
    ],
    "bypass_protection": [
      "$WORKDIR/.zshrc",
      "$WORKDIR/.zprofile"
    ]
  },
  "environment": {
    "allow_vars": [
      "PATH",
      "HOME",
      "TERM",
      "LANG",
      "LC_ALL",
      "USER",
      "SHELL",
      "PWD",
      "XDG_*",
      "HUB_*",
      "OPENCODE_*"
    ],
    "deny_vars": [
      "OPENAI_API_KEY",
      "ANTHROPIC_API_KEY",
      "GITHUB_TOKEN",
      "GPT_UIO_YELLOW_API_KEY",
      "GPT_UIO_RED_API_KEY"
    ]
  },
  "network": {
    "credentials": [
      "github-copilot"
    ],
    "custom_credentials": {
      "github-copilot": {
        "upstream": "https://api.github.com",
        "credential_key": "env://GITHUB_TOKEN",
        "env_var": "GITHUB_TOKEN",
        "inject_header": "Authorization",
        "credential_format": "token {}"
      }
    }
  }
}
